  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "ninthwave-implementer": {
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "allow",
